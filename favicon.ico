document.addEventListener('DOMContentLoaded', function() {
  // Wait a bit to ensure all Webflow scripts have loaded
  setTimeout(function() {
    // Get the specific form by ID
    const newsletterForm = document.getElementById('wf-form-Marketing-Email-Signup');
    
    if (!newsletterForm) {
      console.log('Newsletter form not found');
      return;
    }
    
    console.log('Found form:', newsletterForm.id);
    
    // Get the email input and submit button by their exact names/IDs
    const emailInput = newsletterForm.querySelector('input[name="EMAIL"]');
    const submitButton = newsletterForm.querySelector('input[type="submit"]');
    
    if (!emailInput || !submitButton) {
      console.log('Email input or submit button not found');
      return;
    }
    
    console.log('Found email input and submit button');
    
    // Create message display element
    const messageDiv = document.createElement('div');
    messageDiv.style.cssText = `
      margin-top: 8px;
      padding: 0;
      display: none;
      font-family: inherit;
      font-size: 14px;
      line-height: 1.4;
      text-align: center;
      color: white;
      background: none;
      border: none;
    `;
    
    // Insert message div after the submit button
    submitButton.parentNode.insertBefore(messageDiv, submitButton.nextSibling);
    
    // Add form submit event listener
    newsletterForm.addEventListener('submit', async function(e) {
      e.preventDefault(); // Prevent default form submission
      e.stopPropagation(); // Stop event bubbling
      
      const email = emailInput.value.trim();
      if (!email) {
        showMessage('❌ Please enter a valid email address.', 'error');
        return;
      }
      
      // Basic email validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        showMessage('❌ Please enter a valid email address.', 'error');
        return;
      }
      
      console.log('Submitting email:', email);
      
      // Show loading state
      const originalButtonText = submitButton.value;
      submitButton.value = 'Please wait...';
      submitButton.disabled = true;
      messageDiv.style.display = 'none';
      
      try {
        // Send as form data (application/x-www-form-urlencoded)
        const formData = new URLSearchParams();
        formData.append('EMAIL', email); // Use 'EMAIL' to match your form field name
        
        console.log('Sending to API...');
        
        const response = await fetch('https://api.sogni.ai/v1/task/verification/email/subscribe', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
          },
          body: formData
        });
        
        console.log('Response status:', response.status);
        
        const result = await response.json();
        console.log('Response data:', result);
        
        // Handle response
        if (response.ok && result.status === 'success') {
          // Hide the email input and submit button after successful submission
          emailInput.style.display = 'none';
          submitButton.style.display = 'none';
          
          // Hide reCAPTCHA after successful submission
          const recaptchaHolder = document.getElementById('recaptchaholder');
          if (recaptchaHolder) {
            recaptchaHolder.style.display = 'none';
          }
          
          // Show success message permanently (no auto-hide)
          showMessage('✅ ' + (result.message || 'Successfully subscribed! Check your email.'), 'success');
          
        } else {
          showMessage('❌ ' + (result.message || 'Something went wrong. Please try again.'), 'error');
          // Reset button for error cases
          submitButton.value = originalButtonText;
          submitButton.disabled = false;
        }
      } catch (error) {
        console.error('Network error:', error);
        showMessage('❌ Network error. Please check your connection and try again.', 'error');
        // Reset button for error cases
        submitButton.value = originalButtonText;
        submitButton.disabled = false;
      }
      
      // Note: We don't reset the button for success cases since we hide it
    });
    
    function showMessage(text, type) {
      messageDiv.textContent = text;
      messageDiv.style.display = 'block';
      
      // Keep consistent white text styling
      messageDiv.style.color = 'white';
      messageDiv.style.background = 'none';
      messageDiv.style.border = 'none';
      
      // No auto-hide for any messages - they stay visible permanently
    }
    
  }, 500); // 500ms delay to ensure Webflow is ready
});
</script></body></html>