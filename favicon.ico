// Wait for the DOM to fully load
document.addEventListener("DOMContentLoaded", function() {
  // Get the email input field and recaptcha holder div by their IDs
  const emailField = document.getElementById("EMAIL");
  const recaptchaHolder = document.getElementById("recaptchaholder");

  // Add an event listener to the email field for the 'focus' event
  emailField.addEventListener("focus", function() {
    // Change the recaptcha holder's display property to 'block'
    recaptchaHolder.style.display = "block";
  });
});

